# ---------------------------------------------------------------------------
#  AdLib Brand Guard — example config. Copy to `.env` and edit, OR just use
#  the web dashboard (it writes config.json). NOTHING here is brand-specific by
#  default — point it at YOUR brand.
# ---------------------------------------------------------------------------

# --- the brand you're protecting ---
BRAND_NAME=ExampleBrand
BRAND_TOKENS=examplebrand,examplepay          # words that identify your brand in ad text (lowercase)
BRAND_DOMAINS=example.com                      # your real domains (legit links)
BRAND_OFFICIAL_PAGES=                          # official FB page names to whitelist (comma)
EXEC_NAMES=                                    # executive names for CEO-bait, any language (comma)

# --- what to search in the Meta Ad Library ---
SEARCH_TERMS=ExampleBrand
SEARCH_COUNTRIES=US                            # ISO-2 codes, comma
SEARCH_ACTIVE_ONLY=1
MAX_ADS=200
SCROLL_PASSES=8
# NOTE: the scraper ALWAYS runs headed — Meta serves an empty page to headless
# browsers. On a headless server, run it behind a virtual display (Xvfb).

# --- detection tuning ---
WEAK_FLAG_THRESHOLD=3
LOGO_MATCH_ENABLED=1
FACE_MATCH_ENABLED=1
LOGO_PHASH_MAX_DIST=10
FACE_MATCH_MIN_SCORE=0.82
# reference images live here (upload via the dashboard, or drop files in):
LOGO_REF_DIR=refs/logos
FACE_REF_DIR=refs/faces

# --- optional Telegram alerts ---
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- web server ---
HOST=127.0.0.1
PORT=8000
